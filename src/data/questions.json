    {
      "id": "p5-q001",
      "type": "part5",
      "category": "verb-tense",
      "difficulty": "easy",
      "question": "The new policy will _____ the company's environmental impact.",
      "options": [
        { "key": "A", "text": "reduce" },
        { "key": "B", "text": "reduces" },
        { "key": "C", "text": "reducing" },
        { "key": "D", "text": "to reduce" }
      ],
      "correctAnswer": "A",
      "explanation": "\"will\" 後面必須接動詞原形 (原形動詞)，因此正確答案是 reduce。"
    },
    {
      "id": "p5-q002",
